# .bashrc_foxy
alias build='colcon build --symlink-install'
alias src='source install/setup.bash'
alias foxy_up='docker compose up -d'
alias foxy_shell='docker compose exec -it foxy_test bash'

# Start turtlesim
alias turtle_start='ros2 run turtlesim turtlesim_node'

# Run nodes (Deprecated: use launch_all)
alias rotate_start='ros2 run turtlesim_logic rotate_turtle'
alias move_start='ros2 run turtlesim_logic move_to_target'

# Unified Launch
alias launch_all='ros2 launch turtlesim_logic turtlesim_logic.launch.py'

# Test Action Goals
alias rotate_90='ros2 action send_goal /closed_loop_drive bt_msgs/action/Drive "{type: \"rotate\", target_value: 90.0, speed: 1.0}" --feedback'
alias move_2_2='ros2 action send_goal /closed_loop_drive bt_msgs/action/Drive "{type: \"move_to\", x: 2.0, y: 2.0, speed: 1.0}" --feedback'
alias arc_r2_90='ros2 action send_goal /closed_loop_drive bt_msgs/action/Drive "{type: \"arc\", target_value: 90.0, speed: 1.0, radius: 2.0}" --feedback'
alias ol_rotate_90='ros2 action send_goal /open_loop_drive bt_msgs/action/Drive "{type: \"rotate\", target_value: 90.0, speed: 1.0}" --feedback'
alias ol_move_2='ros2 action send_goal /open_loop_drive bt_msgs/action/Drive "{type: \"move\", target_value: 2.0, speed: 1.0}" --feedback'

# Automated Sequence Execution
alias run_ol_seq='bash /ros2_ws/scripts/test_ol_square.sh'
alias run_cl_seq='bash /ros2_ws/scripts/test_cl_sequence.sh'
alias run_ol_8='bash /ros2_ws/scripts/test_ol_figure8.sh'
alias run_cl_8='bash /ros2_ws/scripts/test_cl_figure8.sh'
alias record='bash /ros2_ws/scripts/record_rosbag.sh'

echo "--- Foxy Test Environment Loaded ---"
echo "Sequence Commands:"
echo "  run_cl_seq : Run closed-loop square (Coordinates)"
echo "  run_ol_seq : Run open-loop square (Time)"
echo "  run_cl_8   : Run closed-loop figure-8 (P-control)"
echo "  run_ol_8   : Run open-loop figure-8 (Time)"
echo "!!! After changes, run 'build' and 'src' !!!"
